# Supabase Projekt-Settings
# Aus dem Supabase-Dashboard kopieren: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# NUR fuer Seed/Admin-Operationen — niemals im Client benutzen!
# Settings > API > service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Postgres-Connection-String fuer Drizzle/Server-Queries
# Aus Supabase: Settings > Database > Connection String > URI (Mode "Transaction")
# WICHTIG: Mode "Transaction" (Port 6543) fuer Vercel Serverless verwenden
DATABASE_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
